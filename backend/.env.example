EXPEDIA_TAAP_MODE=portal_or_approved_api

# Keep these values backend-only. Do not add them to HTML, CSS, or browser JavaScript.
EXPEDIA_TAAP_USERNAME=
EXPEDIA_TAAP_PASSWORD=
EXPEDIA_RAPID_API_KEY=
EXPEDIA_RAPID_SHARED_SECRET=
EXPEDIA_RAPID_BASE_URL=https://api.ean.com

# Gemini AI chatbot. Create the key in Google AI Studio and keep it backend-only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Public WhatsApp click-to-chat number in international format, numbers only preferred.
# Example: 12505550198
WHATSAPP_BUSINESS_NUMBER=

# Optional WhatsApp Cloud API settings for server-side message sending later.
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_NOTIFY_TO=

# Lead summary email delivery. Without SMTP, leads are stored in backend/leads.
LEAD_RECIPIENT_EMAIL=info@globegotravels.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

PORT=8787
